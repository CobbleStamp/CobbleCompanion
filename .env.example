# --- Persistence ---
# Postgres connection (TLS required in production). Used by the API and migrations.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cobble

# --- LLM gateway ---
# Selects the gateway backend. Phase 0 supports: openrouter | fake
LLM_PROVIDER=openrouter
# OpenRouter credential — secret, never commit a real value.
OPENROUTER_API_KEY=
# Model id passed to the provider.
LLM_MODEL=anthropic/claude-3.5-sonnet

# --- Auth (Auth0 Google SSO) ---
# auth0 (default) gates the app behind Auth0 Universal Login; dev_bypass skips
# Auth0 entirely for local dev (any bearer token resolves to DEV_BYPASS_EMAIL).
AUTH_MODE=dev_bypass
# Required when AUTH_MODE=auth0 — from the CobbleCompanion Auth0 tenant + apps.
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_AUDIENCE=
# Identity used in dev_bypass mode.
DEV_BYPASS_EMAIL=dev@cobble.local
# Web client origin — allowed CORS origin for local cross-origin dev.
APP_URL=http://localhost:3001

# --- Server ---
PORT=3000
