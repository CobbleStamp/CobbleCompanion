# --- Persistence ---
# Postgres connection (TLS required in production). Used by the API and migrations.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cobble

# --- LLM gateway ---
# Selects the gateway backend: openrouter | fake
LLM_PROVIDER=openrouter
# OpenRouter credential — secret, never commit a real value. Required when
# LLM_PROVIDER or EMBEDDING_PROVIDER is openrouter.
OPENROUTER_API_KEY=
# Model id passed to the provider.
LLM_MODEL=anthropic/claude-3.5-sonnet

# --- Embedding gateway (Phase 1, semantic memory) ---
# Selects the embedding backend: openrouter | fake
EMBEDDING_PROVIDER=openrouter
# Embedding model id passed to the provider.
EMBEDDING_MODEL=perplexity/pplx-embed-v1-0.6b
# Embedding vector size — must equal the sections.embedding column dimension.
EMBEDDING_DIM=1024

# --- Ingestion (Phase 1, source reading) ---
# Cheap model for the two ingestion reading passes.
INGESTION_MODEL=google/gemini-2.5-flash
# Upload size cap for source files, in bytes (default 25 MiB).
INGESTION_MAX_BYTES=26214400
# A/B knob: prefix the Pass-2 context header onto embedding inputs (true | false).
USE_CONTEXT_HEADER=true
# Backstop cap on queued + in-flight ingestion runs across all owners.
INGESTION_QUEUE_MAX=100

# --- Cost guardrail (Phase 1) ---
# Per-user daily token cap (LLM + embedding) across all routes.
TOKEN_CAP_PER_DAY=1000000

# --- MCP tool acquisition (Phase 9, docs/companion-tools.md §6) ---
# The developer's MCP server whitelist — the entire trust decision and a single,
# process-wide setting that applies to ALL users. A JSON array; empty (default)
# leaves runtime tool acquisition OFF, so behaviour is unchanged until you list a
# server. Read once at startup, so editing this requires an API restart to apply.
#
# Each entry: { ref, endpoint, label?, authTokenEnv? }
#   ref          Unique, non-empty alias the model connects by (connection rows
#                key on it). Duplicates fail fast at startup.
#   endpoint     The server's HTTP/SSE endpoint. Public http(s) only; it is
#                SSRF-validated, so loopback/private/internal hosts are rejected.
#   label        Optional human-friendly name shown on surfaces.
#   authTokenEnv Optional — the NAME of another env var holding the bearer token
#                (the token itself is never stored here; it is resolved per
#                connection from process.env). Set that var separately, below.
#
# Example (a single authenticated server; keep it one line, no spaces needed):
# MCP_SERVERS=[{"ref":"github","endpoint":"https://mcp.example.com/sse","label":"GitHub Tools","authTokenEnv":"GITHUB_MCP_TOKEN"}]
# GITHUB_MCP_TOKEN=
MCP_SERVERS=[]
# Max tools a companion carries equipped at once (companion-tools.md §4), only meaningful
# when MCP_SERVERS is non-empty. The companion discovers tools via search_tools and loads
# them on demand (reactively, or proactively from procedural memory); beyond this cap the
# least-recently-used equipped tool is unloaded, so per-turn context stays small no matter
# how large the whitelisted catalog is.
MAX_EQUIPPED_TOOLS=8

# --- CLI tool acquisition (Phase 10, companion-tools.md §6) ---
# Directory of CLI tool-definition folders — the CLI track's trust boundary.
# Each subfolder is one whitelisted tool: a TOOL.json (the machine contract:
# `binary`, a short `description`, the model-facing `parameters` JSON Schema, an
# `argv` template mapping validated params -> discrete argv elements, and a
# mandatory `limits` block) + a TOOL.md (the usage prompt shown once the tool is
# equipped). The
# model fills the schema; it never composes a free-form command.
#
# SECURITY: this directory must be READ-ONLY and deployment-controlled (a baked
# image or a read-only mount), and must NOT overlap any path the app writes to
# (uploads, ingestion temp, the CLI scratch dir). Anyone who can write here can
# admit a binary the companion will run. The named binary must be installed on the
# host image; dropping a folder defines how to drive it, it does not install it.
# Overlap with the CLI scratch dir (CLI_SCRATCH_DIR below, or the OS temp dir when
# it is unset) is rejected at startup — the app fails fast rather than boot unsafe.
#
# Empty (default) leaves the CLI track off. Example layout:
#   $CLI_TOOLS_PATH/imagemagick/TOOL.json
#   $CLI_TOOLS_PATH/imagemagick/TOOL.md
CLI_TOOLS_PATH=
# Root for the per-tenant EPHEMERAL working dirs CLI runs execute in (separate from
# CLI_TOOLS_PATH; cleaned up after each run). Empty -> the OS temp dir.
CLI_SCRATCH_DIR=
# Per-run resource ceilings (wall-clock + captured-output bytes) are declared
# per tool in each TOOL.json's mandatory "limits" block — there is no deployment
# default knob.

# --- Auth (Google Sign-In) ---
# google (default) gates the app behind Google Sign-In: the SPA gets a Google
# ID token and the API verifies it against Google's JWKS. dev_bypass skips
# Google entirely for local dev (any bearer token resolves to DEV_BYPASS_EMAIL).
AUTH_MODE=dev_bypass
# Required when AUTH_MODE=google — the OAuth Web client ID (public, not a
# secret). Create it in the Google Cloud Console (see infra/README.md).
GOOGLE_CLIENT_ID=
# Identity used in dev_bypass mode.
DEV_BYPASS_EMAIL=dev@cobble.local
# service_token gates the app for trusted server-to-server consumers. There is no env
# secret — credentials live in the service_registry table. Add one with
#   pnpm --filter @cobble/db service add <client_id>
# Callers then send X-Service-Client-Id + Authorization: Bearer <secret> + X-User-Id.
# Web client origin — allowed CORS origin for local cross-origin dev.
APP_URL=http://localhost:3001

# --- API server ---
# TCP port the Fastify API server binds on (host 0.0.0.0). This is the backend
# the web client (APP_URL) calls; keep it distinct from the web client's port.
PORT=3000

# --- Online tracing (Phase C) — OFF by default (docs/runbook-tracing.md) ---
# none (default) emits nothing; langfuse ships per-turn traces to Langfuse Cloud.
TRACING_PROVIDER=none
# Required when TRACING_PROVIDER=langfuse (secrets).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# HTTPS only (carries keys + payload); http permitted only for localhost.
LANGFUSE_HOST=https://cloud.langfuse.com
# Fraction of turns traced (0..1), deterministic per trace id. 0 = send nothing.
TRACING_SAMPLE_RATE=0
# strict (default, metadata only — no content) | metadata_only (same as strict
# today) | off (sends content with a defensive PII/secret scrub).
TRACING_REDACT=strict
