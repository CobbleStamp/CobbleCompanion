# --- Persistence ---
# Postgres connection (TLS required in production). Used by the API and migrations.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cobble

# --- LLM gateway ---
# Selects the gateway backend. Phase 0 supports: openrouter | fake
LLM_PROVIDER=openrouter
# OpenRouter credential — secret, never commit a real value.
OPENROUTER_API_KEY=
# Model id passed to the provider.
LLM_MODEL=anthropic/claude-3.5-sonnet

# --- Auth (magic link) ---
# Secret used to sign session cookies. Generate a long random value.
AUTH_SESSION_SECRET=change-me-in-production-min-32-chars-long
# Base URL of the web client; magic-link emails point here.
APP_URL=http://localhost:5173
# Email transport: console (dev — logs the link) | smtp (later)
EMAIL_TRANSPORT=console

# --- Server ---
PORT=3000
# Scale-to-zero hot-path minimum (see architecture.md §8). Informational in Phase 0.
MIN_INSTANCES=1
